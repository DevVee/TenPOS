# ============================================================
# TenPOS — Web Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project → Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to use in frontend (RLS enforces security)
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role key — required for staff creation (bypasses email confirmation)
# Get from: Supabase Dashboard → Settings → API → service_role
# WARNING: Never expose this in public repos or client-side code outside Vite build
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
