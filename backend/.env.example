# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/tenpos

# Supabase production (use the connection POOLER URL for serverless / Vercel):
#   Dashboard → Project Settings → Database → Connection Pooling → Connection string
#   Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#   Add ?pgbouncer=true if using Transaction mode pooler
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Local:
CORS_ORIGIN=http://localhost:5173
# Production (your Vercel frontend URL):
# CORS_ORIGIN=https://your-tenpos-frontend.vercel.app

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
